{
    "rules": {
        "admins": {
            ".read": "auth != null",
            ".write": "auth.token.email === 'raghavbhatia332@gmail.com'"
        },
        "licenses": {
            ".read": "auth != null",
            ".write": "auth.token.email === 'raghavbhatia332@gmail.com'",
            "$licenseId": {
                ".read": "true",
                "lastActive": {
                    ".write": "true"
                }
            }
        },
        "settings": {
            ".read": "true",
            ".write": "auth != null"
        },
        "menu": {
            ".read": "true",
            ".write": "auth != null",
            ".indexOn": ["category"]
        },
        "offers": {
            ".read": "true",
            ".write": "auth != null"
        },
        "categories": {
            ".read": "true",
            ".write": "auth != null"
        },
        "sessions": {
            ".read": "true",
            "$sessionId": {
                ".write": "auth != null || !data.exists() || data.child('status').val() != 'completed'",
                ".indexOn": [
                    "status"
                ]
            }
        },
        "orders": {
            ".read": "true",
            ".write": "true",
            ".indexOn": [
                "timestamp"
            ]
        },
        "tables": {
            ".read": "true",
            ".write": "true"
        },
        "waiter_calls": {
            ".read": "true",
            ".write": "true"
        },
        ".read": false,
        ".write": false
    }
}